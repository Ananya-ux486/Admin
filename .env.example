# Copy to .env for server/runtime values and optionally .env.local for
# browser-exposed NEXT_PUBLIC_* values. Never commit real credentials.

NODE_ENV=development
# The unified server defaults to 3001. Hosting providers normally inject PORT.
PORT=3001

# Shared public-site data and private admin-only data must remain separate.
MONGODB_SHARED_URI=mongodb+srv://USER:PASSWORD@HOST/tasmafiveDB?retryWrites=true&w=majority
MONGODB_ADMIN_URI=mongodb+srv://USER:PASSWORD@HOST/tasmafiveAdminDB?retryWrites=true&w=majority

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-long-unique-password
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters

# Exact admin frontend origins; no wildcard. Production entries must use HTTPS.
ADMIN_ORIGINS=http://localhost:3001,https://admin.tasmafivesolutions.com
PUBLIC_SITE_URL=http://localhost:3000
ADMIN_COOKIE_DOMAIN=

# Browser-visible customer site used for generated payment links.
NEXT_PUBLIC_USER_SITE_URL=http://localhost:3000
